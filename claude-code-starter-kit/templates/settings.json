{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Read(.)",
      "Edit(.)",
      "Write(.)",
      "Glob(.)",
      "Grep(.)",
      "WebSearch",

      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git add *)",
      "Bash(git commit *)",

      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cd *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(sleep *)",

      "Bash({{PACKAGE_MANAGER}} *)",
      "Bash({{TEST_COMMAND}})",
      "Bash({{LINT_COMMAND}})",
      "Bash({{TYPE_CHECK_COMMAND}})",
      "Bash({{BUILD_COMMAND}})",

      "Bash(docker compose *)",
      "Bash(docker exec *)",
      "Bash(docker cp *)",
      "Bash(docker port *)",
      "Bash(docker logs *)",
      "Bash(docker ps *)",

      "Bash(curl -s *)",

      "mcp__ide__getDiagnostics",
      "mcp__ide__executeCode"
    ],

    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(docker system prune *)",
      "Bash(DROP TABLE *)",
      "Bash(DROP DATABASE *)"
    ]
  },

  "env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'File modified — remember to run /review-changes or the code-reviewer + test-runner pipeline'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/log-agent-activity.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
