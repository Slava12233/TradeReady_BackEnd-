# Price Ingestion Service — Binance WebSocket → Redis + TimescaleDB
# Shares the same base image/deps as the API service but runs the ingestion entry point.
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
  && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ ./src/

CMD ["python", "-m", "src.price_ingestion.service"]
