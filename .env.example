# AI Agent Crypto Trading Platform — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=agentexchange
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=agentexchange
DATABASE_URL=postgresql+asyncpg://agentexchange:change_me_in_production@timescaledb:5432/agentexchange

# ─── Redis ───────────────────────────────────────────────────────────────────
# No password needed — Redis runs on internal Docker network only (no host port).
REDIS_URL=redis://redis:6379/0

# ─── Binance WebSocket ───────────────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/stream

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to "production" on the server. Enables weak-credential startup assertions.
ENVIRONMENT=development

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=https://api.agentexchange.com

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Add your production frontend URL.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://tradeready.io,https://www.tradeready.io

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change_me_to_random_64_char_string
JWT_EXPIRY_HOURS=1

# ─── Trading Defaults ────────────────────────────────────────────────────────
DEFAULT_STARTING_BALANCE=10000
TRADING_FEE_PCT=0.1
DEFAULT_SLIPPAGE_FACTOR=0.1

# ─── Tick Ingestion ──────────────────────────────────────────────────────────
TICK_FLUSH_INTERVAL=1.0
TICK_BUFFER_MAX_SIZE=5000

# ─── Celery ──────────────────────────────────────────────────────────────────
# Both default to REDIS_URL if not set. Override here to use a separate Redis DB.
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── Monitoring ──────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me

# ─── pgAdmin (dev profile only) ──────────────────────────────────────────────
# Only used when starting with: docker compose --profile dev up pgadmin
# Change these before using pgAdmin. NOT started in production.
PGADMIN_EMAIL=admin@tradeready.io
PGADMIN_PASSWORD=changeme

# ─── Alertmanager ────────────────────────────────────────────────────────────
# Alertmanager SMTP credentials are configured directly in monitoring/alertmanager.yml
# (Alertmanager does not support env var substitution in its config file).
# After first deploy, edit monitoring/alertmanager.yml on the server to set:
#   smtp_smarthost, smtp_from, smtp_auth_username, smtp_auth_password
#   and the 'to' address under receivers[0].email_configs[0].
