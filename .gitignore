# ─── Agent Local Memory (not shared) ────────────────────────────────────────
.claude/agent-memory-local/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
lib/
lib64/
MANIFEST

# ─── Virtual Environments ────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ─── Secrets ─────────────────────────────────────────────────────────────────
# Never commit .env — use .env.example as template
.env
*.pem
*.key
*.crt

# ─── Testing & Coverage ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover
*.py,cover

# ─── Type Checking ───────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ─── Linting ─────────────────────────────────────────────────────────────────
.ruff_cache/

# ─── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ─── Docker ──────────────────────────────────────────────────────────────────
.dockerignore

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ─── Claude Code (personal settings — shared settings.json IS committed) ──
.claude/settings.local.json

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Alembic ─────────────────────────────────────────────────────────────────
# Keep migrations, but ignore generated pycache inside alembic
alembic/__pycache__/
alembic/versions/__pycache__/

# ─── Monitoring data ─────────────────────────────────────────────────────────
prometheus_data/
grafana_data/

Frontend/


# ─── Agent reports (generated output, not source) ────────────────────────────
agent/reports/

# ─── ML model artefacts (trained weights — generated output, not source) ─────
agent/strategies/*/models/*.joblib
agent/strategies/*/models/*.pkl
agent/strategies/*/models/*.pt
agent/strategies/*/models/*.pth
agent/strategies/*/models/*.zip
agent/strategies/*/models/logs/
agent/strategies/*/models/checkpoint/
agent/strategies/*/models/best_model/
agent/strategies/rl/results/*.json

# ─── Obsidian (development vault) ─────────────────────────────────────────
# Commit .obsidian/ config but exclude workspace state and local plugin caches
development/.obsidian/workspace.json
development/.obsidian/workspace-mobile.json
development/.obsidian/.obsidian-git
development/.obsidian/plugins/*/data.json
!development/.obsidian/plugins/dataview/data.json


ssh.txt